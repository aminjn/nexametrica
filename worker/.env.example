# آدرس API سایت تو — حتماً با /api تمام شود
API_BASE=https://nexametrica.ir/api

# اگر روی سرور WORKER_TOKEN گذاشتی، همان مقدار را اینجا هم بگذار (اختیاری)
WORKER_TOKEN=

# مدل YOLO: سبک‌تر=سریع‌تر، سنگین‌تر=دقیق‌تر
# گزینه‌ها: yolo11n.pt < yolo11s.pt < yolo11m.pt < yolo11l.pt < yolo11x.pt
# روی 3070 8GB، m یا l پیشنهاد می‌شود.
MODEL=yolo11m.pt

# آستانه‌ی اطمینان تشخیص
CONF=0.3

# هر چند فریم یک‌بار پردازش شود (۳ = سریع‌تر، ۱ = دقیق‌تر/کندتر)
SAMPLE=3

# اندازه‌ی ورودی مدل (اگر VRAM کم آورد ۹۶۰ بگذار)
IMGSZ=1280

# 0 = GPU ، cpu = پردازنده
DEVICE=0

# --- کالیبراسیونِ خودکارِ زمین (per-frame) — کاملاً لوکال، بدونِ هیچ API ---
# 1 = روشن. مدل یک فایلِ محلی است (مثلِ همان yolo). هیچ تماسِ خارجی موقعِ اجرا نیست.
# قبلش یک‌بار اجرا کن:  bash download-pitch-model.sh   (فایل را در models/pitch.pt می‌گذارد)
PITCH=1
# هر چند فریمِ پردازش‌شده یک‌بار مدلِ زمین اجرا شود (۲ خوب است؛ دوربین آرام می‌چرخد)
PITCH_EVERY=2
# مسیرِ مدل؛ اگر خالی باشد به‌صورت پیش‌فرض worker/models/pitch.pt استفاده می‌شود.
PITCH_MODEL_PATH=

# --- خواندنِ شماره‌ی پیراهن (Jersey OCR) — کاملاً لوکال، اختیاری ---
# 1 = روشن. هویتِ واقعیِ بازیکن + اتصالِ درستِ ردها. نیاز به نصبِ easyocr دارد
# (یک‌بار ~۶۴ مگ وزن دانلود می‌شود، بعد آفلاین روی GPU). روی ۷۲۰p+ خوب کار می‌کند؛
# روی ۳۶۰p شماره‌ها ریزند و کم خوانده می‌شود.
JERSEY=0
JERSEY_EVERY=6
