# کلید و آدرس ارائه‌دهنده‌ی LLM — این فایل را به .env کپی کن و مقادیر را بگذار.
# نکته (ایران): api.openai.com معمولاً از سرور ایران بلاک است؛ LLM_BASE_URL را به
# گیت‌وی/پروکسیِ OpenAI-compatible خودت یا اندپوینت Gemini بگذار.

# OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
# Google Gemini (OpenAI-compatible):
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   LLM_MODEL=gemini-2.0-flash
# DeepSeek:
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat

# این‌ها فقط مقدار اولیه‌اند؛ بعد از راه‌اندازی، همه را از پنل سوپر ادمین
# می‌توانی تغییر بدهی (در server/data/settings.json ذخیره می‌شود).
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# توکن ادمین: برای دسترسی به تنظیمات API از پنل سوپر ادمین لازم است.
# یک رشته‌ی تصادفیِ قوی بگذار (مثلاً خروجی: openssl rand -hex 24).
# همین توکن را یک‌بار در پنل سوپر ادمین وارد می‌کنی.
ADMIN_TOKEN=

# دامنه‌هایی که اجازه‌ی صدا زدن API را دارند (با کاما). برای شروع * هم اوکی است.
CORS_ORIGINS=*
