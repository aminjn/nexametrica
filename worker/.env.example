# آدرس API سایت تو — حتماً با /api تمام شود
API_BASE=https://mt.nexxaai.ir/api

# اگر روی سرور WORKER_TOKEN گذاشتی، همان مقدار را اینجا هم بگذار (اختیاری)
WORKER_TOKEN=

# مدل YOLO (سبک‌تر = سریع‌تر، سنگین‌تر = دقیق‌تر):
#   yolo11n.pt < yolo11s.pt < yolo11m.pt < yolo11l.pt < yolo11x.pt
# روی 3070 8GB، m یا l پیشنهاد می‌شود.
MODEL=yolo11m.pt

CONF=0.3        # آستانه‌ی اطمینان تشخیص
SAMPLE=3        # هر چند فریم یک‌بار پردازش شود (۳ = سریع‌تر)
IMGSZ=1280      # اندازه‌ی ورودی مدل
DEVICE=0        # 0 = GPU ، cpu = پردازنده
