# آدرس API سایت تو — حتماً با /api تمام شود
API_BASE=https://mt.nexxaai.ir/api

# اگر روی سرور WORKER_TOKEN گذاشتی، همان مقدار را اینجا هم بگذار (اختیاری)
WORKER_TOKEN=

# مدل YOLO: سبک‌تر=سریع‌تر، سنگین‌تر=دقیق‌تر
# گزینه‌ها: yolo11n.pt < yolo11s.pt < yolo11m.pt < yolo11l.pt < yolo11x.pt
# روی 3070 8GB، m یا l پیشنهاد می‌شود.
MODEL=yolo11m.pt

# آستانه‌ی اطمینان تشخیص
CONF=0.3

# هر چند فریم یک‌بار پردازش شود (۳ = سریع‌تر، ۱ = دقیق‌تر/کندتر)
SAMPLE=3

# اندازه‌ی ورودی مدل (اگر VRAM کم آورد ۹۶۰ بگذار)
IMGSZ=1280

# 0 = GPU ، cpu = پردازنده
DEVICE=0

# --- کالیبراسیونِ خودکارِ زمین (per-frame) — پیشرفته/اختیاری ---
# پیش‌فرض خاموش (0). برای روشن‌کردن به یک فایلِ مدلِ نقاطِ زمین نیاز است که فقط
# یک‌بار باید تهیه شود (هیچ سرویس/کلیدِ خارجی موقعِ اجرا لازم نیست — کاملاً آفلاین).
# تا وقتی این 0 است، ورکر کاملاً آفلاین کار می‌کند و کالیبراسیونِ دستیِ ۴-گوشه فعال است.
PITCH=0
# هر چند فریمِ پردازش‌شده یک‌بار مدلِ زمین اجرا شود (۲ خوب است؛ دوربین آرام می‌چرخد)
PITCH_EVERY=2
# مسیرِ فایلِ محلیِ مدلِ نقاطِ زمین روی Z440 (وقتی PITCH=1 شد پُرش می‌کنیم)
PITCH_MODEL_PATH=
